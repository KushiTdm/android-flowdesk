{
  "expo": {
    "name": "FlowDesk",
    "slug": "FlowDesk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/FlowDesk_logo.png",
    "scheme": "flowdesk",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.admin.flowdesk",
      "adaptiveIcon": {
        "backgroundColor": "#F2F0FA",
        "foregroundImage": "./assets/images/FlowDesk_logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "allowBackup": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/FlowDesk_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/FlowDesk_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F2F0FA",
          "dark": {
            "backgroundColor": "#1A1934"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2d1fb3d5-c89b-4627-8f7f-7afcb2bf5a27"
      }
    }
  }
}
